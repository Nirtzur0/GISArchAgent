# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LangSmith (Optional - for tracing)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=gis-arch-agent

# Vector Database
CHROMA_PERSIST_DIRECTORY=./data/vectorstore

# ArcGIS (if needed for authenticated access)
ARCGIS_USERNAME=
ARCGIS_PASSWORD=

# iPlan System
IPLAN_BASE_URL=https://ags.iplan.gov.il/xplan/
IPLAN_API_URL=https://ags.iplan.gov.il/arcgisiplan/rest/services/PlanningPublic/

# Application Settings
LOG_LEVEL=INFO
MAX_TOKENS=4000
TEMPERATURE=0.1
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
