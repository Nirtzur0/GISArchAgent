# Canonical provider configuration for synthesis and upload analysis.
# Leave OPENAI_API_KEY blank when your local endpoint does not require auth.
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini

# Optional local overrides.
GISARCHAGENT_BACKEND_HOST=127.0.0.1
GISARCHAGENT_BACKEND_PORT=8000
GISARCHAGENT_FRONTEND_HOST=127.0.0.1
GISARCHAGENT_FRONTEND_PORT=5173
GISARCHAGENT_DATA_FILE=data/raw/iplan_layers.json
GISARCHAGENT_CACHE_DIR=data/cache
GISARCHAGENT_VECTORSTORE_DIR=data/vectorstore
